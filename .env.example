# ── Meridian Capital Partners · .env.example ────────────────────────────
# Copy to .env and fill in your keys.
# .env is gitignored — never commit real credentials.

# ── API keys ───────────────────────────────────────────────────────────
# Claude / Anthropic API (Layer 3 — AI analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Alpaca Markets (Layer 6 — execution)
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...

# Polygon.io (optional, for richer market data)
POLYGON_API_KEY=

# ── Database ───────────────────────────────────────────────────────────
DB_PATH=cache/meridian.db

# Ollama endpoint (Layer 7 — reporting)
OLLAMA_ENDPOINT=http://localhost:11434/api

DB_PATH=cache/meridian.db
